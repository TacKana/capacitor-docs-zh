{
  "headers": [
    {
      "source": "/ds-test",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/apis/storage", "destination": "/apis/preferences" },
    { "source": "/cli/commands/list", "destination": "/cli/commands/ls" },
    { "source": "/next/:match*", "destination": "/:match*" }
  ],
  "rewrites": [{ "source": "/:match*", "destination": "/:match*" }]
}
